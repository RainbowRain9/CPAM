[Unit]
Description=API Center local service
After=network.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/Code/cli-proxy-API-Center
ExecStart=/root/Code/cli-proxy-API-Center/scripts/start-local.sh
Restart=always
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=7940
User=root

[Install]
WantedBy=multi-user.target
